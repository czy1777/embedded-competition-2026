# AI 分析提供商配置。默认使用 mock,不调用真实 API,不需要 API key。
# 想切换到 DeepSeek/OpenAI/通义千问等:改 AI_PROVIDER + 填 AI_API_KEY。

# 可选值: mock | deepseek | openai
# (openai 复用同一 client,只是 base_url 不同)
AI_PROVIDER=mock

# DeepSeek: sk-xxx (https://platform.deepseek.com)
# OpenAI:   sk-xxx (https://platform.openai.com)
AI_API_KEY=

# DeepSeek: deepseek-chat (V3.x) 或 deepseek-reasoner (R1)
# OpenAI:   gpt-4o / gpt-4.1-mini
AI_MODEL=deepseek-chat

# DeepSeek:     https://api.deepseek.com/v1
# OpenAI:       https://api.openai.com/v1
# 通义(兼容):  https://dashscope.aliyuncs.com/compatible-mode/v1
AI_BASE_URL=https://api.deepseek.com/v1

# 单次调用超时 (毫秒)
AI_TIMEOUT_MS=30000
